@* =============================================
   File: Views/Products/Details.cshtml
   Framework: ASP.NET Core MVC
   ============================================= *@
@model ProductCRUD.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-eye me-2"></i>Product Details</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">ID</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4 text-muted">Product Name</dt>
                    <dd class="col-sm-8"><strong>@Model.Name</strong></dd>

                    <dt class="col-sm-4 text-muted">Price</dt>
                    <dd class="col-sm-8 text-success fs-5">₹@Model.Price.ToString("N2")</dd>

                    <dt class="col-sm-4 text-muted">Quantity</dt>
                    <dd class="col-sm-8">
                        @if (Model.Quantity < 5)
                        {
                            <span class="badge bg-danger fs-6">@Model.Quantity (Low Stock)</span>
                        }
                        else
                        {
                            <span class="badge bg-success fs-6">@Model.Quantity in stock</span>
                        }
                    </dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
                    <i class="bi bi-pencil me-1"></i>Edit
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm">
                    <i class="bi bi-trash me-1"></i>Delete
                </a>
                <a asp-action="Index" class="btn btn-secondary btn-sm ms-auto">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>
