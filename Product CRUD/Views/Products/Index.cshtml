@* =============================================
   File: Views/Products/Index.cshtml
   Framework: ASP.NET Core MVC
   Note: Uses asp-action / asp-route-id Tag Helpers
         instead of @Url.Action() / Html.ActionLink()
   ============================================= *@
@model IEnumerable<ProductCRUD.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0"><i class="bi bi-list-ul me-2 text-primary"></i>All Products</h2>
        <small class="text-muted">@Model.Count() product(s) in inventory</small>
    </div>
    @* Tag Helper: asp-action generates the correct href automatically *@
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add New Product
    </a>
</div>

@if (Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Product Name</th>
                        <th>Price (₹)</th>
                        <th>Quantity</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td class="text-muted">@product.Id</td>
                            <td><strong>@product.Name</strong></td>
                            <td>₹@product.Price.ToString("N2")</td>
                            <td>
                                @if (product.Quantity < 5)
                                {
                                    <span class="badge bg-danger">@product.Quantity (Low)</span>
                                }
                                else
                                {
                                    <span>@product.Quantity</span>
                                }
                            </td>
                            <td class="text-center action-buttons">
                                @* asp-route-id passes the id route value *@
                                <a asp-action="Details" asp-route-id="@product.Id"
                                   class="btn btn-sm btn-outline-info" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@product.Id"
                                   class="btn btn-sm btn-outline-warning" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@product.Id"
                                   class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox display-3"></i>
        <p class="mt-3 fs-5">No products found.</p>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add Your First Product
        </a>
    </div>
}
