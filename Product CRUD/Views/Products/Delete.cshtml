@* =============================================
   File: Views/Products/Delete.cshtml
   Framework: ASP.NET Core MVC
   ============================================= *@
@model ProductCRUD.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h5>
            </div>
            <div class="card-body">

                <p class="text-muted mb-4">
                    Are you sure you want to permanently delete this product?
                    <strong>This action cannot be undone.</strong>
                </p>

                <dl class="row">
                    <dt class="col-sm-4 text-muted">ID</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4 text-muted">Product Name</dt>
                    <dd class="col-sm-8"><strong>@Model.Name</strong></dd>

                    <dt class="col-sm-4 text-muted">Price</dt>
                    <dd class="col-sm-8">₹@Model.Price.ToString("N2")</dd>

                    <dt class="col-sm-4 text-muted">Quantity</dt>
                    <dd class="col-sm-8">@Model.Quantity</dd>
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i>Yes, Delete
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>
