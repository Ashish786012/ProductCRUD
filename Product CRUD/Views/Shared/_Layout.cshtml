@* =============================================
   File: Views/Shared/_Layout.cshtml
   Framework: ASP.NET Core MVC
   Key differences from MVC 5:
     - asp-action / asp-controller tag helpers replace @Html.ActionLink()
     - asp-antiforgery is handled automatically in forms
   ============================================= *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] – Product Manager</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 700; letter-spacing: 1px; }
        .table thead { background-color: #0d6efd; color: white; }
        .action-buttons a, .action-buttons button { margin: 0 2px; }
    </style>
</head>
<body>

    @* ---- Navbar — uses ASP.NET Core Tag Helpers (asp-controller, asp-action) ---- *@
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand" asp-controller="Products" asp-action="Index">
                <i class="bi bi-box-seam me-2"></i>Product Manager
            </a>
            <div>
                <a class="btn btn-light btn-sm" asp-controller="Products" asp-action="Create">
                    <i class="bi bi-plus-circle me-1"></i>Add Product
                </a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">

        @* ---- Flash message (set via TempData in the controller) ---- *@
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

   <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>